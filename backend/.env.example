# Server
PORT=4000
NODE_ENV=development
# Bisa lebih dari satu origin, dipisahkan koma. Jangan gunakan wildcard (*).
CLIENT_URL=http://localhost:3000

# Database (MySQL 8.0.24+, spatial support built-in — no extension needed)
DATABASE_URL="mysql://user:password@localhost:3306/akseskota"

# JWT
JWT_ACCESS_SECRET=change_this_access_secret
JWT_REFRESH_SECRET=change_this_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cloudinary (foto laporan & bukti kondisi jalur)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Gunakan "local" saat development, "cloudinary" saat production.
UPLOAD_STORAGE=local

# Rate limiting laporan (F012 acceptance criteria)
REPORT_RATE_LIMIT_WINDOW_MS=3600000
REPORT_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
VERIFICATION_RATE_LIMIT_WINDOW_MS=3600000
VERIFICATION_RATE_LIMIT_MAX=60

# Hanya digunakan saat menjalankan: npm run seed:admin
ADMIN_NAME=Admin AksesKota
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ganti_dengan_password_minimal_12_karakter

# Hanya untuk seed data contoh lokal. Jangan aktifkan pada production.
ALLOW_DEMO_SEED=false
DEMO_ADMIN_PASSWORD=
DEMO_USER_PASSWORD=
